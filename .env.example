GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
DATABASE_URL=
# Required at signup (POST /api/register) so strangers can't self-register
# and start spending your Groq quota. Leave unset only for local dev.
REGISTRATION_CODE=
# Set to "false" only for local http:// dev — cookies default to Secure,
# which requires HTTPS (Render always serves HTTPS).
COOKIE_SECURE=
